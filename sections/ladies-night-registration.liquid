<script>
  (function() {
    var VARIANT_ID = 42234240958519;
    var STORE = 'https://247restaurantequipment.com';
    var PRICE = 50;
    var currentQty = 1;

    var opts = document.querySelectorAll('.ln-ticket-opt');
    var summaryCount = document.getElementById('ln-summary-count');
    var summaryTotal = document.getElementById('ln-summary-total');
    var btnText = document.getElementById('ln-btn-text');
    var checkoutBtn = document.getElementById('ln-checkout-btn');

    function updateUI(qty) {
      currentQty = qty;
      var total = qty * PRICE;
      summaryCount.textContent = qty === 1 ? '1 ticket' : qty + ' tickets';
      summaryTotal.innerHTML = '$' + total + ' <span>due at checkout</span>';
      btnText.textContent = 'Reserve ' + qty + (qty === 1 ? ' Ticket' : ' Tickets') + ' \u2014 $' + total;
    }

    opts.forEach(function(opt) {
      opt.addEventListener('click', function() {
        opts.forEach(function(o) { o.classList.remove('selected'); });
        this.classList.add('selected');
        updateUI(parseInt(this.querySelector('input').value));
      });
    });

    checkoutBtn.addEventListener('click', function() {
      var fname = document.getElementById('ln-fname').value.trim();
      var lname = document.getElementById('ln-lname').value.trim();
      var email = document.getElementById('ln-email').value.trim();
      var phone = document.getElementById('ln-phone').value.trim();
      var referral = document.getElementById('ln-referral').value;
      var notes = document.getElementById('ln-notes').value.trim();


      var noteParts = [];
      if (fname || lname) noteParts.push('Name: ' + (fname + ' ' + lname).trim());
      if (email)          noteParts.push('Email: ' + email);
      if (phone)          noteParts.push('Phone: ' + phone);
      if (referral)       noteParts.push('Heard via: ' + referral);
      if (notes)          noteParts.push('Notes: ' + notes);

      var noteString = noteParts.join(' | ');
      var url = STORE + '/cart/' + VARIANT_ID + ':' + currentQty
              + '?checkout&note=' + encodeURIComponent(noteString);

      window.location.href = url;
    });
  })();
</script>

