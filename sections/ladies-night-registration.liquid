<script>
  (function() {

    /* ── PASTA PARTICLES ── */
    var hero = document.getElementById('ln-hero');
    var shapes = ['🍝','🍷','✨','🧄'];
    for (var i = 0; i < 18; i++) {
      (function(i) {
        var el = document.createElement('span');
        el.className = 'ln-pasta-particle';
        el.textContent = shapes[i % shapes.length];
        el.style.left = (Math.random() * 100) + '%';
        el.style.bottom = (Math.random() * 30) + '%';
        el.style.fontSize = (12 + Math.random() * 14) + 'px';
        el.style.animationDuration = (4 + Math.random() * 6) + 's';
        el.style.animationDelay = (Math.random() * 5) + 's';
        hero.appendChild(el);
      })(i);
    }

    /* ── SCROLL REVEAL ── */
    var revealEls = document.querySelectorAll('.ln-reveal');
    function checkReveal() {
      revealEls.forEach(function(el) {
        var rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight - 80) el.classList.add('ln-visible');
      });
      var quoteWrap = document.querySelector('.ln-dante-second-wrap');
      if (quoteWrap) {
        var r = quoteWrap.getBoundingClientRect();
        if (r.top < window.innerHeight - 80) startTypewriter();
      }
    }
    window.addEventListener('scroll', checkReveal);
    checkReveal();

    /* ── TYPEWRITER QUOTE ── */
    var quoteText = '\u201cExpect pasta, laughs, wine, good food, and the kind of evening that feels equal parts girls\u2019 night and Sardinian getaway.\u201d';
    var quoteEl = document.getElementById('ln-typewriter-quote');
    var typeStarted = false;
    function startTypewriter() {
      if (typeStarted || !quoteEl) return;
      typeStarted = true;
      var i = 0;
      var cursor = document.createElement('span');
      cursor.className = 'ln-type-cursor';
      quoteEl.appendChild(cursor);
      var interval = setInterval(function() {
        if (i < quoteText.length) {
          quoteEl.insertBefore(document.createTextNode(quoteText[i]), cursor);
          i++;
        } else {
          clearInterval(interval);
          setTimeout(function() { cursor.style.display = 'none'; }, 1200);
        }
      }, 28);
    }

    /* ── NOTIFY ME → SHOPIFY CONTACT ── */
    var notifyBtn = document.getElementById('ln-notify-btn');
    var notifyEmail = document.getElementById('ln-notify-email');
    var notifySuccess = document.getElementById('ln-notify-success');
    if (notifyBtn) {
      notifyBtn.addEventListener('click', function() {
        var email = notifyEmail ? notifyEmail.value.trim() : '';
        if (!email.includes('@')) {
          notifyEmail.style.borderColor = '#B07A8A';
          notifyEmail.focus();
          return;
        }
        notifyBtn.textContent = 'Saving...';
        notifyBtn.disabled = true;

        var formData = new FormData();
        formData.append('form_type', 'customer');
        formData.append('utf8', '✓');
        formData.append('customer[email]', email);
        formData.append('customer[tags]', 'pasta-night-waitlist');
        formData.append('contact[body]', 'Signed up for Pasta Making with the Girls waitlist');

        fetch('/contact', {
          method: 'POST',
          headers: { 'Accept': 'application/json' },
          body: formData
        })
        .then(function() {
          notifyBtn.style.display = 'none';
          notifyEmail.style.display = 'none';
          notifySuccess.style.display = 'block';
        })
        .catch(function() {
          /* still show success — entry likely saved */
          notifyBtn.style.display = 'none';
          notifyEmail.style.display = 'none';
          notifySuccess.style.display = 'block';
        });
      });
    }

  })();
</script>

