<style>
  [data-section-id="{{ section.id }}"] {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  [data-section-id="{{ section.id }}"] .why-us__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--spacing-section-horizontal, 2rem);
  }

  /* Header */
  [data-section-id="{{ section.id }}"] .why-us__header {
    text-align: center;
    margin-bottom: {{ section.settings.header_gap }}px;
  }

  [data-section-id="{{ section.id }}"] .why-us__eyebrow {
    font-family: var(--font-base);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.6);
    margin: 0 0 12px;
  }

  [data-section-id="{{ section.id }}"] .why-us__heading {
    font-family: var(--font-headline);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.1;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 16px;
  }

  @media (max-width: 749px) {
    [data-section-id="{{ section.id }}"] .why-us__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }

  [data-section-id="{{ section.id }}"] .why-us__subheading {
    font-family: var(--font-base);
    font-size: {{ section.settings.subheading_size }}px;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Reasons Grid */
  [data-section-id="{{ section.id }}"] .why-us__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns }}, 1fr);
    gap: {{ section.settings.item_gap }}px;
    margin-bottom: {{ section.settings.grid_bottom_gap }}px;
  }

  @media (max-width: 899px) {
    [data-section-id="{{ section.id }}"] .why-us__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 549px) {
    [data-section-id="{{ section.id }}"] .why-us__grid {
      grid-template-columns: 1fr;
    }
  }

  /* Reason item */
  [data-section-id="{{ section.id }}"] .why-us__item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: {{ section.settings.item_padding }}px;
    background-color: rgba(255,255,255,{{ section.settings.item_bg_opacity | divided_by: 100.0 }});
    border-radius: {{ section.settings.item_radius }}px;
    border: 1px solid rgba(255,255,255,0.15);
  }

  [data-section-id="{{ section.id }}"] .why-us__item-icon {
    width: 36px;
    height: 36px;
    background-color: {{ section.settings.icon_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  [data-section-id="{{ section.id }}"] .why-us__item-icon svg {
    width: 18px;
    height: 18px;
    fill: #ffffff;
  }

  [data-section-id="{{ section.id }}"] .why-us__item-text {
    flex: 1;
  }

  [data-section-id="{{ section.id }}"] .why-us__item-title {
    font-family: var(--font-headline);
    font-size: {{ section.settings.item_title_size }}px;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 6px;
    line-height: 1.2;
  }

  [data-section-id="{{ section.id }}"] .why-us__item-body {
    font-family: var(--font-base);
    font-size: {{ section.settings.item_body_size }}px;
    color: rgba(255,255,255,0.75);
    line-height: 1.55;
    margin: 0;
  }

  /* Divider */
  [data-section-id="{{ section.id }}"] .why-us__divider {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.2);
    margin: 0 0 {{ section.settings.cta_gap }}px;
  }

  /* CTA */
  [data-section-id="{{ section.id }}"] .why-us__cta {
    text-align: center;
  }

  [data-section-id="{{ section.id }}"] .why-us__cta-heading {
    font-family: var(--font-headline);
    font-size: {{ section.settings.cta_heading_size }}px;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 8px;
    line-height: 1.15;
  }

  @media (max-width: 749px) {
    [data-section-id="{{ section.id }}"] .why-us__cta-heading {
      font-size: {{ section.settings.cta_heading_size_mobile }}px;
    }
  }

  [data-section-id="{{ section.id }}"] .why-us__cta-sub {
    font-family: var(--font-base);
    font-size: {{ section.settings.cta_sub_size }}px;
    color: rgba(255,255,255,0.7);
    margin: 0 0 28px;
    line-height: 1.5;
  }

  [data-section-id="{{ section.id }}"] .why-us__cta-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  [data-section-id="{{ section.id }}"] .why-us__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-headline);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    padding: 14px 36px;
    border-radius: var(--border-radius-button, 30px);
    transition: all 0.2s ease;
    cursor: pointer;
    border: 2px solid transparent;
  }

  [data-section-id="{{ section.id }}"] .why-us__btn--primary {
    background-color: {{ section.settings.btn_primary_bg }};
    color: {{ section.settings.btn_primary_text }};
    border-color: {{ section.settings.btn_primary_bg }};
  }

  [data-section-id="{{ section.id }}"] .why-us__btn--primary:hover {
    opacity: 0.88;
    transform: translateY(-2px);
  }

  [data-section-id="{{ section.id }}"] .why-us__btn--secondary {
    background-color: transparent;
    color: #ffffff;
    border-color: rgba(255,255,255,0.6);
  }

  [data-section-id="{{ section.id }}"] .why-us__btn--secondary:hover {
    background-color: rgba(255,255,255,0.1);
    border-color: #ffffff;
    transform: translateY(-2px);
  }
</style>

<div data-section-id="{{ section.id }}" class="why-us">
  <div class="why-us__inner">

    <!-- Header -->
    <div class="why-us__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="why-us__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="why-us__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="why-us__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <!-- Reasons Grid -->
    <div class="why-us__grid">
      {%- for block in section.blocks -%}
        <div class="why-us__item" {{ block.shopify_attributes }}>
          <div class="why-us__item-icon">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          </div>
          <div class="why-us__item-text">
            {%- if block.settings.title != blank -%}
              <p class="why-us__item-title">{{ block.settings.title }}</p>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="why-us__item-body">{{ block.settings.body }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    <!-- Divider -->
    <hr class="why-us__divider">

    <!-- CTA -->
    <div class="why-us__cta">
      {%- if section.settings.cta_heading != blank -%}
        <h3 class="why-us__cta-heading">{{ section.settings.cta_heading }}</h3>
      {%- endif -%}
      {%- if section.settings.cta_sub != blank -%}
        <p class="why-us__cta-sub">{{ section.settings.cta_sub }}</p>
      {%- endif -%}
      <div class="why-us__cta-buttons">
        {%- if section.settings.btn1_label != blank -%}
          <a href="{{ section.settings.btn1_link }}" class="why-us__btn why-us__btn--primary">
            {{ section.settings.btn1_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.btn2_label != blank -%}
          <a href="{{ section.settings.btn2_link }}" class="why-us__btn why-us__btn--secondary">
            {{ section.settings.btn2_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

  </div>
</div>

{% schema %}
{
