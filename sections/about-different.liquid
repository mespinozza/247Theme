<style>
  [data-section-id="{{ section.id }}"] {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  [data-section-id="{{ section.id }}"] .about-diff__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--spacing-section-horizontal, 2rem);
  }

  /* Section Header */
  [data-section-id="{{ section.id }}"] .about-diff__header {
    text-align: {{ section.settings.header_align }};
    margin-bottom: {{ section.settings.header_gap }}px;
  }

  [data-section-id="{{ section.id }}"] .about-diff__eyebrow {
    font-family: var(--font-base);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: {{ section.settings.accent_color }};
    margin: 0 0 12px;
  }

  [data-section-id="{{ section.id }}"] .about-diff__heading {
    font-family: var(--font-headline);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.1;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    margin: 0 0 16px;
  }

  @media (max-width: 749px) {
    [data-section-id="{{ section.id }}"] .about-diff__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }

  [data-section-id="{{ section.id }}"] .about-diff__subheading {
    font-family: var(--font-base);
    font-size: {{ section.settings.subheading_size }}px;
    color: {{ section.settings.body_color }};
    line-height: 1.6;
    max-width: 640px;
    {% if section.settings.header_align == 'center' %}margin: 0 auto;{% endif %}
  }

  /* Cards Grid */
  [data-section-id="{{ section.id }}"] .about-diff__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  @media (max-width: 899px) {
    [data-section-id="{{ section.id }}"] .about-diff__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
  }

  /* Card */
  [data-section-id="{{ section.id }}"] .about-diff__card {
    background-color: {{ section.settings.card_bg_color }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: {{ section.settings.card_padding }}px;
    position: relative;
    overflow: hidden;
    {% if section.settings.card_border %}
    border: 1px solid {{ section.settings.card_border_color }};
    {% endif %}
    display: flex;
    flex-direction: column;
  }

  [data-section-id="{{ section.id }}"] .about-diff__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background-color: {{ section.settings.accent_color }};
    border-radius: 4px 0 0 4px;
  }

  /* Step number */
  [data-section-id="{{ section.id }}"] .about-diff__step {
    font-family: var(--font-headline);
    font-size: 72px;
    line-height: 1;
    color: {{ section.settings.accent_color }};
    opacity: 0.12;
    position: absolute;
    top: 12px;
    right: 20px;
    pointer-events: none;
    user-select: none;
  }

  /* Icon */
  [data-section-id="{{ section.id }}"] .about-diff__icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    background-color: {{ section.settings.accent_color }};
    border-radius: {{ section.settings.icon_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    flex-shrink: 0;
  }

  [data-section-id="{{ section.id }}"] .about-diff__icon svg {
    width: calc({{ section.settings.icon_size }}px * 0.5);
    height: calc({{ section.settings.icon_size }}px * 0.5);
    fill: #ffffff;
  }

  /* Card text */
  [data-section-id="{{ section.id }}"] .about-diff__card-eyebrow {
    font-family: var(--font-base);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: {{ section.settings.accent_color }};
    margin: 0 0 8px;
  }

  [data-section-id="{{ section.id }}"] .about-diff__card-title {
    font-family: var(--font-headline);
    font-size: {{ section.settings.card_title_size }}px;
    line-height: 1.15;
    text-transform: uppercase;
    color: {{ section.settings.card_title_color }};
    margin: 0 0 12px;
  }

  [data-section-id="{{ section.id }}"] .about-diff__card-body {
    font-family: var(--font-base);
    font-size: {{ section.settings.card_body_size }}px;
    line-height: 1.65;
    color: {{ section.settings.body_color }};
    margin: 0;
    flex: 1;
  }

  /* Connector arrows between cards (desktop only) */
  [data-section-id="{{ section.id }}"] .about-diff__connector {
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.accent_color }};
    opacity: 0.4;
    font-size: 24px;
    align-self: center;
  }

  @media (max-width: 899px) {
    [data-section-id="{{ section.id }}"] .about-diff__connector {
      display: none;
    }
  }

  /* CTA line */
  [data-section-id="{{ section.id }}"] .about-diff__cta {
    margin-top: 48px;
    text-align: center;
    padding-top: 40px;
    border-top: 1px solid {{ section.settings.card_border_color }};
  }

  [data-section-id="{{ section.id }}"] .about-diff__cta-text {
    font-family: var(--font-headline);
    font-size: {{ section.settings.cta_size }}px;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    margin: 0 0 20px;
  }

  [data-section-id="{{ section.id }}"] .about-diff__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: {{ section.settings.accent_color }};
    color: #ffffff;
    font-family: var(--font-headline);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    padding: 14px 32px;
    border-radius: var(--border-radius-button, 30px);
    transition: opacity 0.2s ease;
  }

  [data-section-id="{{ section.id }}"] .about-diff__cta-btn:hover {
    opacity: 0.85;
  }
</style>

<div data-section-id="{{ section.id }}" class="about-diff">
  <div class="about-diff__inner">

    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="about-diff__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="about-diff__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="about-diff__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="about-diff__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="about-diff__grid">

      <!-- Card 1: Consultation -->
      <div class="about-diff__card">
        <span class="about-diff__step">01</span>
        <div class="about-diff__icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
        </div>
        <p class="about-diff__card-eyebrow">Step 01</p>
        <h3 class="about-diff__card-title">{{ section.settings.card1_title }}</h3>
        <p class="about-diff__card-body">{{ section.settings.card1_body }}</p>
      </div>

      <!-- Card 2: Installation -->
      <div class="about-diff__card">
        <span class="about-diff__step">02</span>
        <div class="about-diff__icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/></svg>
        </div>
        <p class="about-diff__card-eyebrow">Step 02</p>
        <h3 class="about-diff__card-title">{{ section.settings.card2_title }}</h3>
        <p class="about-diff__card-body">{{ section.settings.card2_body }}</p>
      </div>

      <!-- Card 3: Service -->
      <div class="about-diff__card">
        <span class="about-diff__step">03</span>
        <div class="about-diff__icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 4l5 2.18V11c0 3.5-2.33 6.79-5 7.93-2.67-1.14-5-4.43-5-7.93V7.18L12 5z"/></svg>
        </div>
        <p class="about-diff__card-eyebrow">Step 03</p>
        <h3 class="about-diff__card-title">{{ section.settings.card3_title }}</h3>
        <p class="about-diff__card-body">{{ section.settings.card3_body }}</p>
      </div>

    </div>

    {%- if section.settings.show_cta -%}
      <div class="about-diff__cta">
        {%- if section.settings.cta_text != blank -%}
          <p class="about-diff__cta-text">{{ section.settings.cta_text }}</p>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link }}" class="about-diff__cta-btn">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
