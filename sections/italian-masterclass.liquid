<script>
  // Variant selector — updates the hidden Shopify form input
  function imcSelectVariant(el) {
    document.querySelectorAll('.imc-v-opt').forEach(o => o.classList.remove('imc-active'));
    el.classList.add('imc-active');
    const variantId = el.getAttribute('data-variant-id');
    const hiddenInput = document.getElementById('imc-variant-id');
    if (hiddenInput && variantId) hiddenInput.value = variantId;
  }

  // FAQ accordion
  function imcToggleFaq(btn) {
    const item = btn.parentElement;
    const open = item.classList.contains('imc-open');
    document.querySelectorAll('.imc-faq-item').forEach(f => {
      f.classList.remove('imc-open');
      f.querySelector('.imc-faq-icon').textContent = '+';
    });
    if (!open) {
      item.classList.add('imc-open');
      btn.querySelector('.imc-faq-icon').textContent = '×';
    }
  }
</script>

