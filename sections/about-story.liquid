{% assign bg_rgb = section.settings.background_color | color_to_rgb %}
{% assign accent_rgb = section.settings.accent_color | color_to_rgb %}

<style>
  [data-section-id="{{ section.id }}"] {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  [data-section-id="{{ section.id }}"] .about-story__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 var(--spacing-section-horizontal, 2rem);
  }

  [data-section-id="{{ section.id }}"] .about-story__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.column_gap }}px;
    align-items: center;
  }

  @media (max-width: 899px) {
    [data-section-id="{{ section.id }}"] .about-story__layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  /* Image Side */
  [data-section-id="{{ section.id }}"] .about-story__image-wrap {
    position: relative;
  }

  [data-section-id="{{ section.id }}"] .about-story__image {
    width: 100%;
    height: {{ section.settings.image_height }}px;
    object-fit: cover;
    border-radius: {{ section.settings.image_radius }}px;
    display: block;
  }

  [data-section-id="{{ section.id }}"] .about-story__image-badge {
    position: absolute;
    bottom: -20px;
    {% if section.settings.image_position == 'left' %}
      right: -20px;
    {% else %}
      left: -20px;
    {% endif %}
    background-color: {{ section.settings.accent_color }};
    color: {{ section.settings.badge_text_color }};
    border-radius: 50%;
    width: 110px;
    height: 110px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    padding: 12px;
  }

  [data-section-id="{{ section.id }}"] .about-story__badge-number {
    font-family: var(--font-headline);
    font-size: 32px;
    line-height: 1;
    font-weight: 900;
  }

  [data-section-id="{{ section.id }}"] .about-story__badge-label {
    font-size: 11px;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: 2px;
  }

  /* Text Side */
  [data-section-id="{{ section.id }}"] .about-story__eyebrow {
    font-family: var(--font-base);
    font-size: {{ section.settings.eyebrow_size }}px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: {{ section.settings.accent_color }};
    margin: 0 0 12px;
  }

  [data-section-id="{{ section.id }}"] .about-story__heading {
    font-family: var(--font-headline);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.1;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    margin: 0 0 24px;
  }

  @media (max-width: 749px) {
    [data-section-id="{{ section.id }}"] .about-story__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }
  }

  [data-section-id="{{ section.id }}"] .about-story__body {
    font-family: var(--font-base);
    font-size: {{ section.settings.body_size }}px;
    line-height: 1.7;
    color: {{ section.settings.body_color }};
    margin: 0 0 32px;
  }

  [data-section-id="{{ section.id }}"] .about-story__body p {
    margin: 0 0 16px;
  }

  [data-section-id="{{ section.id }}"] .about-story__body p:last-child {
    margin-bottom: 0;
  }

  /* Stats Bar */
  [data-section-id="{{ section.id }}"] .about-story__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-top: 40px;
    padding-top: 40px;
    border-top: 2px solid {{ section.settings.divider_color }};
  }

  @media (max-width: 599px) {
    [data-section-id="{{ section.id }}"] .about-story__stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  [data-section-id="{{ section.id }}"] .about-story__stat {
    text-align: {{ section.settings.stat_align }};
  }

  [data-section-id="{{ section.id }}"] .about-story__stat-number {
    font-family: var(--font-headline);
    font-size: {{ section.settings.stat_number_size }}px;
    line-height: 1;
    color: {{ section.settings.accent_color }};
    display: block;
  }

  [data-section-id="{{ section.id }}"] .about-story__stat-label {
    font-family: var(--font-base);
    font-size: {{ section.settings.stat_label_size }}px;
    color: {{ section.settings.stat_label_color }};
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 4px;
    display: block;
    line-height: 1.3;
  }
</style>

<div data-section-id="{{ section.id }}" class="about-story">
  <div class="about-story__inner">

    <div class="about-story__layout" style="direction: {% if section.settings.image_position == 'right' %}rtl{% else %}ltr{% endif %};">

      {%- if section.settings.image != blank -%}
        <div class="about-story__image-wrap" style="direction: ltr;">
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            alt="{{ section.settings.image.alt | escape }}"
            class="about-story__image"
            loading="lazy"
            width="900"
          >
          {%- if section.settings.show_badge -%}
            <div class="about-story__image-badge">
              <span class="about-story__badge-number">{{ section.settings.badge_number }}</span>
              <span class="about-story__badge-label">{{ section.settings.badge_label }}</span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="about-story__text" style="direction: ltr;">
        {%- if section.settings.eyebrow != blank -%}
          <p class="about-story__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="about-story__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="about-story__body">{{ section.settings.body }}</div>
        {%- endif -%}

        {%- if section.settings.show_stats -%}
          <div class="about-story__stats">
            {%- for i in (1..4) -%}
              {%- assign num_key = 'stat_' | append: i | append: '_number' -%}
              {%- assign label_key = 'stat_' | append: i | append: '_label' -%}
              {%- if section.settings[num_key] != blank -%}
                <div class="about-story__stat">
                  <span class="about-story__stat-number">{{ section.settings[num_key] }}</span>
                  <span class="about-story__stat-label">{{ section.settings[label_key] }}</span>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "About — Our Story",
  "tag": "section",
  "settings": [
    {
      "type": "header",
